# SQLite for local development. For production use a Postgres connection string
# and switch the datasource provider in prisma/schema.prisma to "postgresql".
DATABASE_URL="file:./dev.db"

# Protects the /admin area. Change before deploying anywhere.
ADMIN_PASSWORD="changeme"

# Store slug used when no domain/cookie/query resolves to a tenant (local dev).
NEXT_PUBLIC_DEFAULT_STORE="drones"

# When "true", checkout simulates a successful order without charging anyone.
# Set to "false" once a real payment provider is wired into
# src/lib/payments/payment-provider.ts.
MOCK_CHECKOUT="true"
