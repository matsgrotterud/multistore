# Neon Postgres — TWO connection strings (both from neon.tech → Connect):
#
# 1) POOLED (for app runtime on Vercel + local dev):
#    Host contains "-pooler". Used as DATABASE_URL everywhere the app runs.
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"
#
# 2) DIRECT (for migrations / db push / seed only — run from your machine):
#    Host does NOT contain "-pooler". Used as DIRECT_URL when running prisma CLI.
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# Protects the /admin area. Change before deploying anywhere.
ADMIN_PASSWORD="changeme"

# Store slug used when no domain/cookie/query resolves to a tenant (local dev).
NEXT_PUBLIC_DEFAULT_STORE="drones"

# When "true", checkout simulates a successful order without charging anyone.
# Set to "false" once a real payment provider is wired into
# src/lib/payments/payment-provider.ts.
MOCK_CHECKOUT="true"

# Optional: override preview URL host (defaults to VERCEL_URL on Vercel).
# Example: https://multistore-virid.vercel.app
NEXT_PUBLIC_SITE_URL="https://multistore-virid.vercel.app"

# --- Supplier image sync (daily cron + npm run sync:supplier-images) ---
# Protects /api/cron/sync-supplier-catalog on Vercel.
CRON_SECRET="generate-a-long-random-string"

# AliExpress Open Platform (recommended — fast + stable product images).
# Register at https://portals.aliexpress.com/
ALIEXPRESS_APP_KEY=""
ALIEXPRESS_APP_SECRET=""
# Optional affiliate tracking id from AliExpress affiliate dashboard.
ALIEXPRESS_TRACKING_ID=""

# Jina Reader fallback when AliExpress API keys are not set (slower).
# https://jina.ai/reader/
JINA_API_KEY=""

# Sync tuning (optional)
SUPPLIER_SYNC_DELAY_MS="800"
SUPPLIER_FETCH_TIMEOUT_MS="45000"
# Set to 1 to fetch full AliExpress product pages via Jina (slower, more images).
SUPPLIER_FETCH_DETAIL="0"
